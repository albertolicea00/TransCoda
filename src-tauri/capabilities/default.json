{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for TransCoda main and settings windows",
  "windows": [
    "main",
    "settings"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "allow-update_tray_status",
    "allow-set_close_to_tray",
    "allow-open_settings_window"
  ]
}
